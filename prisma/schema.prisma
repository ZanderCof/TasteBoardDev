generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Aggiungi queste tabelle per TasteBoard
model Restaurant {
  id           String   @id @default(cuid())
  userId       String   @unique // Collego l'ID utente che arriva da StartingLine
  name         String
  address      String?
  logo         String?
  type         String?  // Ristorante, Pizzeria, Bar...
  categories   Category[]
  createdAt    DateTime @default(now())
}

model Category {
  id           String   @id @default(cuid())
  name         String   // Antipasti, Primi, Bevande...
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items        MenuItem[]
  order        Int      @default(0) // Per ordinare le categorie nel menu
}

model MenuItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  image       String?
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  available   Boolean  @default(true)
}
