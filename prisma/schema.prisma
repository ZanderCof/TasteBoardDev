generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Reservation {
  id           String   @id @default(cuid())
  customerName String
  email        String?
  phone        String
  date         DateTime
  guests       Int
  notes        String?
  status       Status   @default(PENDING)

  // ➕ NUOVO: Capire se arriva dal sito (false) o se il ristoratore l'ha presa al telefono (true)
  isManual Boolean @default(false)

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // 🪑 MODIFICATO: Invece di una stringa di testo libera, colleghiamo la prenotazione a un tavolo reale
  tableId String?
  table   Table?  @relation(fields: [tableId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Status {
  PENDING // Richiesta dal sito, in attesa
  CONFIRMED // Approvata dal proprietario
  DECLINED // ➕ NUOVO: Rifiutata dal proprietario
  CANCELLED // Annullata (magari dal cliente stesso)
}

model Restaurant {
  id           String        @id @default(cuid())
  userId       String
  name         String
  address      String?
  logo         String?
  type         String?
  menus        Menu[]
  reservations Reservation[]
  tables       Table[] // ➕ NUOVO: Il locale ha la sua mappa dei tavoli
  createdAt    DateTime      @default(now())
}

model Table {
  id           String        @id @default(cuid())
  name         String // Es: "Tavolo 1", "Terrazza 4"
  minCapacity  Int           @default(1) // ➕ NUOVO: Posti minimi
  maxCapacity  Int // 🔄 MODIFICATO: Sostituisce la vecchia "capacity"
  restaurantId String
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  reservations Reservation[]
}

/**
 * I modelli Menu, Category e Dish rimangono IDENTICI ai tuoi
 * perché la logica è già impeccabile.
 */
model Menu {
  id           String     @id @default(cuid())
  name         String
  isPublished  Boolean    @default(false)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  categories   Category[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt // 👈 AGGIUNGI QUESTO
}

model Category {
  id     String @id @default(cuid())
  name   String
  order  Int    @default(0)
  menuId String
  menu   Menu   @relation(fields: [menuId], references: [id], onDelete: Cascade)
  dishes Dish[]
}

model ActivityLog {
  id           String   @id @default(cuid())
  userId       String?
  userEmail    String?
  restaurantId String?
  action       String
  entityId     String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([restaurantId, createdAt])
  @@index([action, createdAt])
}

model Feedback {
  id         String   @id @default(cuid())
  userId     String?
  rating     Int
  bug        String?
  suggestion String?
  createdAt  DateTime @default(now())
}

model Ticket {
  id           String         @id @default(cuid())
  userId       String?
  userEmail    String?
  restaurantId String?
  subject      String
  content      String
  category     TicketCategory @default(ALTRO)
  priority     TicketPriority @default(MEDIUM)
  hubTicketId  String?
  createdAt    DateTime       @default(now())
}

enum TicketCategory {
  GESTIONE_MENU
  PAGAMENTO
  PRENOTAZIONI
  ACCOUNT
  ALTRO
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Dish {
  id          String  @id @default(cuid())
  name        String
  description String?
  price       Decimal @db.Decimal(10, 2)
  image       String?
  available   Boolean @default(true) // ← NUOVO CAMPO

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("dish")
}
